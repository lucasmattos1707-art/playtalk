# Copie para .env e preencha os valores.
# No Render, configure essas variáveis no dashboard (Environment).

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_SSL=true
JWT_SECRET=troque-por-um-segredo-forte
PORT=3000

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=0bd95b85090f7aadd8c395824f46b5c6
R2_BUCKET_NAME=playtalk-media
R2_ACCESS_KEY_ID=troque-pela-access-key
R2_SECRET_ACCESS_KEY=troque-pela-secret-key
R2_ENDPOINT=https://0bd95b85090f7aadd8c395824f46b5c6.r2.cloudflarestorage.com

# Estrutura de conteudo no R2
# Mantive "contnent" porque foi o nome combinado na conversa.
# Se quiser corrigir para "content" depois, basta trocar aqui.
R2_CONTENT_ROOT=contnent
R2_CONTENT_DAYS=200
R2_CONTENT_PHASES=12
R2_CONTENT_MARKER_FILE=.keep
R2_CONTENT_CONCURRENCY=8

# ElevenLabs TTS
# Troque pelos valores reais da sua conta.
ELEVENLABS_API_KEY=sk_fake_elevenlabs_substitua_pela_real
ELEVENLABS_VOICE_ID_HARRY=voice_fake_harry_substitua_pelo_real
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# OpenAI Images
# Use uma chave real da OpenAI e mantenha ela apenas no servidor.
OPENAI_API_KEY=sk-proj-substitua-pela-chave-real
OPENAI_IMAGE_MODEL=gpt-image-1-mini
OPENAI_TEXT_MODEL=gpt-5-mini
