{
    "name": "game",
    "version": "1.0.0",
    "description": "Fluency game",
    "main": "server.js",
    "scripts": {
        "prebuild": "npm run sync:levels",
        "prestart": "npm run build",
        "start": "node server.js",
        "build": "node build-static.js",
        "cap:sync": "npm run build && npx cap sync android",
        "cap:copy": "npm run build && npx cap copy android",
        "cap:open:android": "npx cap open android",
        "sync:levels": "node scripts/sync-local-level-assets.js",
        "test": "echo \"Error: no test specified\" && exit 1",
        "r2:init-content": "node scripts/init-r2-content.js",
        "r2:flashcards": "node scripts/publish-flashcards-r2.js",
        "r2:accesskey": "node scripts/upload-r2-folder.js --source=accesskey --prefix=accesskey --concurrency=4",
        "r2:audiostuto": "node scripts/upload-r2-folder.js --source=audiostuto --prefix=audiostuto --concurrency=4",
        "db:reset:users": "node scripts/reset-users-table.js",
        "keys:generate": "node scripts/generate-access-keys.js",
        "deploy:pages": "npm run build && npx wrangler pages deploy dist"
    },
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1017.0",
        "@capacitor/app": "^7.1.2",
        "@capacitor/browser": "^7.0.5",
        "@capacitor/core": "^7.6.1",
        "@capacitor/keyboard": "^7.0.6",
        "@capacitor/splash-screen": "^7.0.5",
        "@capacitor/status-bar": "^7.0.6",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "express": "^4.19.2",
        "jsonwebtoken": "^9.0.2",
        "pg": "^8.12.0",
        "sharp": "^0.34.5"
    },
    "devDependencies": {
        "@capacitor/android": "^7.6.1",
        "@capacitor/cli": "^7.6.1",
        "typescript": "^5.9.3"
    }
}
